# Copy to .env and fill in. .env is gitignored.

# -----------------------------------------------------------------------------
# Testnet
# -----------------------------------------------------------------------------
# 24-word seed phrase. Generate via `clarinet integrate` or any BIP-39 tool.
# Fund from https://platform.hiro.so/faucet — testnet STX has no real value.
TESTNET_DEPLOYER_MNEMONIC=""
TESTNET_DEPLOYER_PRINCIPAL="ST..."

# -----------------------------------------------------------------------------
# Mainnet — DO NOT FILL IN UNTIL READY TO DEPLOY
# -----------------------------------------------------------------------------
# Treat this mnemonic with the same care as a wallet seed. If it appears in
# git history it is permanently compromised; rotate immediately.
MAINNET_DEPLOYER_MNEMONIC=""

# Public Stacks principal derived from MAINNET_DEPLOYER_MNEMONIC.
# Example value the user supplied: SP3PXGYYR9Y7GCQKNDWTWJW4R1YMAZ97VKSDWAGB8
# The deploy-mainnet.sh script verifies the mnemonic produces this principal
# before broadcasting any tx, and refuses to deploy if they don't match.
MAINNET_DEPLOYER_PRINCIPAL=""

# -----------------------------------------------------------------------------
# Hiro API
# -----------------------------------------------------------------------------
# Optional — gives 2k req/min instead of 100. Get one at
# https://platform.hiro.so/settings/api-keys
HIRO_API_KEY=""

# -----------------------------------------------------------------------------
# Deploy gating
# -----------------------------------------------------------------------------
# `deploy-mainnet.sh` refuses to run unless this is exactly "true".
# Setting it documents that:
#   1. The contract has been audited (or you accept the risk).
#   2. The testnet plan was applied AND end-to-end tested.
#   3. The mainnet legal/jurisdictional implications were reviewed.
MAINNET_AUDIT_ACK="false"

# Default network for clarinet commands.
NETWORK="testnet"
