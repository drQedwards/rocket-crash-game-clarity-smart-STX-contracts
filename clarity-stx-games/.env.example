# Copy to .env for local tooling. Do not commit secrets.
# Clarinet itself does NOT expand environment variables inside settings/*.toml.
# These values are for off-clarinet tooling (scripts, dashboards, etc.) and for
# pre-deploy substitution if your CI pipeline templates settings/Testnet.toml.

STACKS_NETWORK=testnet
PROJECT_OWNER=SP3PXGYYR9Y7GCQKNDWTWJW4R1YMAZ97VKSDWAGB8

# Deployer values are intentionally blank. Use a fresh testnet account first.
STACKS_DEPLOYER_ADDRESS=
STACKS_DEPLOYER_MNEMONIC=

# Optional API/RPC configuration for Hiro tooling.
HIRO_API_KEY=
STACKS_API_URL=https://api.testnet.hiro.so

# Signed-randomness template.
ORACLE_PUBLIC_KEY_HEX=
ORACLE_PRIVATE_KEY_HEX=

# Token wager template. Fill with the concrete sBTC or SIP-010 contract principal
# for the selected network.
SIP010_TOKEN_CONTRACT=
